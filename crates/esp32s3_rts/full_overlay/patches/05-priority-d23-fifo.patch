+   ------------------
+   -- Set_Priority --  (cross-task)
+   ------------------
+
+   procedure Set_Priority (Id : Thread_Id; Priority : Integer) is
+   begin
+      Protection.Enter_Kernel;
+
+      --  Minimal cross-task priority RAISE: only a thread NOT on the
+      --  ready queue (Suspended/Delayed) on the current CPU.  We only
+      --  record the active priority -- the target is not in the ready
+      --  queue, so no reorder is needed and NO context switch can happen
+      --  here (the caller may hold RTS locks; a switch mid-rendezvous-
+      --  setup corrupts requeue/abort paths).  Queues.Insert honours the
+      --  recorded priority when the target is woken (ACATS CXD2003).  A
+      --  Runnable target keeps the base-priority path.
+      if Id /= Null_Thread_Id
+        and then Id.State /= Runnable
+        and then Get_CPU (Id) = Get_CPU (Queues.Running_Thread)
+        and then Priority > Id.Active_Priority
+      then
+         Id.Active_Priority := Priority;
+      end if;
+
+      Protection.Leave_Kernel;
+   end Set_Priority;
+
+   -----------
+   -- Yield --
+   -----------
+
+   procedure Yield is
+   begin
+      Protection.Enter_Kernel;
+
+      --  D.2.3: move the running thread to the tail of its active-priority
+      --  ready queue (base-priority set must trail same-priority peers).
+      Queues.Yield (Queues.Running_Thread);
+
+      Protection.Leave_Kernel;
+   end Yield;
+
