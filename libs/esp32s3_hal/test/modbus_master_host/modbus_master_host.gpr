--  Native (x86) host harness for Modbus.Master.  Modbus.Master is written against
--  the GNAT.Sockets subset, so the SAME source compiles against the native
--  runtime's real GNAT.Sockets here (our bare-metal facade is NOT a source -- the
--  whitelist leaves it out), and runs against the stdlib Python slave.  See run.sh.
project Modbus_Master_Host is
   for Source_Dirs use (".", "../../src");
   for Object_Dir use "obj";
   for Exec_Dir use ".";
   for Main use ("modbus_master_host.adb");
   for Source_Files use
     ("modbus_master_host.adb",
      "modbus.ads",          "modbus.adb",
      "modbus-master.ads",   "modbus-master.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-g", "-O0", "-gnata", "-gnat2022");
   end Compiler;
end Modbus_Master_Host;
