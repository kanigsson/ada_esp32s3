--  Native (x86) host test for the pure-Ada LISP core.  No bare-metal runtime, no
--  hardware -- the interpreter is plain Ada.  See run.sh.
project Lisp_Test is
   for Source_Dirs use (".", "../../src");
   for Object_Dir use "obj";
   for Exec_Dir use ".";
   for Main use ("lisp_test.adb");
   package Compiler is
      for Default_Switches ("Ada") use ("-g", "-O0", "-gnata", "-gnat2022");
   end Compiler;
end Lisp_Test;
